# 哨兵 Sentinel 环境变量配置
# 复制为 .env 后填入真实值

# MySQL 连接（用于多步验证 runner 的数据库检查步骤）
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/Online_Shopping_System

# Redis 地址（用于多步验证 runner 的缓存检查步骤）
REDIS_ADDR=127.0.0.1:6379

# 飞书机器人 Webhook（任务失败时推送告警卡片）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_KEY_HERE

# 电商系统管理员密码（runner 登录用）
ADMIN_PASSWORD=CHANGE_ME
